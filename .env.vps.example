# Configuration deploiement VPS (utilise par scripts/deploy-vps.mjs)
# Copie ce fichier en .env.vps et remplis les valeurs reelles.
# Le fichier .env.vps n'est PAS committe (gitignore) car contient infos sensibles.

# ─── Connexion SSH ────────────────────────────────────────────────────────────
VPS_SSH_HOST=vps112526.serveur-vps.net
VPS_SSH_USER=obrilleshell
VPS_SSH_KEY=~/.ssh/obrille_temp

# ─── Cible sur le VPS ─────────────────────────────────────────────────────────
# Dossier racine de l'app React sur le VPS (sera cree si inexistant).
VPS_APP_DIR=/web/landings-app

# ─── Variables d'environnement injectees au build ────────────────────────────
# URL de l'API. Par defaut on utilise le proxy PHP same-origin
# (/web/api/index.php sur le VPS) qui forward vers le backend Vercel.
# Avantage : same-origin -> resout les blocages du navigateur in-app de
# Facebook/Instagram qui bloquait les requetes cross-origin vers vercel.app.
# Si tu veux pointer directement Vercel : VITE_API_URL=https://gs-pipeline-app-2.vercel.app/api
VITE_API_URL=/api

# URL Socket.io (admin chat). Optionnel, fallback sur backend Vercel.
VITE_SOCKET_URL=https://gs-pipeline-app-2.vercel.app

# Prefixe URL des assets generes par Vite. DOIT correspondre a VPS_APP_DIR.
# Exemple : si VPS_APP_DIR=/web/landings-app -> VITE_BASE_PATH=/landings-app/
VITE_BASE_PATH=/landings-app/

# ─── Tests automatiques apres deploy ──────────────────────────────────────────
# Domaine public utilise pour tester les URLs (sans protocole).
PUBLIC_DOMAIN=obrille.com

# Liste des slugs landings a tester, separes par des virgules.
LANDING_SLUGS=creme-anti-verrue,creme-verrue-tk,spraydouleurtk,creme-ongle-incarne,chaussette-compression,patchdouleurtk,crememinceurfb
