# ========================================
# BASE DE DONNEES
# ========================================
DATABASE_URL=postgresql://user:password@host:port/database?schema=public
DIRECT_URL=postgresql://user:password@host:port/database?schema=public

# ========================================
# AUTHENTIFICATION
# ========================================
JWT_SECRET=votre_secret_jwt_ici

# ========================================
# WEBHOOK (Google Apps Script / Make)
# ========================================
MAKE_WEBHOOK_API_KEY=votre_api_key_webhook
WEBHOOK_API_KEY=votre_api_key_webhook

# ========================================
# SUPABASE
# ========================================
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key
SUPABASE_CHAT_BUCKET=chat

# ========================================
# FRONTEND
# ========================================
FRONTEND_URL=https://www.obgestion.com
CORS_ORIGINS=https://www.obgestion.com,https://bf.obgestion.com

# ========================================
# META CONVERSIONS API (Facebook Pixel)
# ========================================
META_PIXEL_ID=votre_pixel_id_meta
META_ACCESS_TOKEN=votre_access_token_meta

# ========================================
# WHATSAPP AGENT (360dialog + Deepgram)
# ========================================
WHATSAPP_PROVIDER=360DIALOG
DIALOG360_API_KEY=votre_360dialog_api_key
DIALOG360_API_URL=https://waba-v2.360dialog.io/v1
DIALOG360_WEBHOOK_SECRET=votre_webhook_verify_token

TRANSCRIPTION_PROVIDER=DEEPGRAM
DEEPGRAM_API_KEY=votre_deepgram_api_key

# Toggle bot on/off
WA_BOT_ENABLED=true
# Seuil confiance minimum (0-100) avant handoff automatique
WA_CONFIDENCE_THRESHOLD=40
# Nombre max echecs bot avant handoff
WA_MAX_BOT_FAILURES=3
# Company ID par defaut pour les messages entrants
WA_DEFAULT_COMPANY_ID=1
# Nom commercial affiche dans les reponses bot
WA_BUSINESS_NAME=OB Gestion
